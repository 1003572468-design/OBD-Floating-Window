<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OBD 悬浮窗显示器"
        android:textSize="22sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="状态: 未启动"
        android:textSize="14sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="悬浮窗高度调节"
        android:textSize="14sp"
        android:textColor="#cccccc"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <SeekBar
            android:id="@+id/seekbar_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="60"
            android:min="35"
            android:progress="50"/>

        <TextView
            android:id="@+id/tv_size_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="50 dp"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btn_start_service"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="启动悬浮窗"
            android:backgroundTint="#4CAF50"/>

        <Button
            android:id="@+id/btn_stop_service"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="停止服务"
            android:backgroundTint="#f44336"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_select_data"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="选择显示的数据"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 使用说明:\n• 长按悬浮窗数据项可打开选择器\n• 拖动悬浮窗移动位置\n• 点击悬浮窗展开/收缩"
        android:textSize="12sp"
        android:textColor="#888888"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
